#!/usr/bin/env bash
#
# Triggers a rollback if the system stays uncommitted too long after boot.
# Waits until WATCHDOG_TIMEOUT seconds after boot, then checks whether
# the active partition group matches the default. If not, reboots to
# fall back to the previous known-good system.

set -euo pipefail

WATCHDOG_TIMEOUT=1800

# shellcheck disable=SC1091
[ -f /etc/nexigon-rugix-watchdog.conf ] && source /etc/nexigon-rugix-watchdog.conf

UPTIME=$(awk '{print int($1)}' /proc/uptime)
REMAINING=$((WATCHDOG_TIMEOUT - UPTIME))

if [ "$REMAINING" -gt 0 ]; then
    echo "[INFO] waiting ${REMAINING}s (timeout=${WATCHDOG_TIMEOUT}s, uptime=${UPTIME}s)" >&2
    sleep "$REMAINING"
fi

SYSTEM_INFO=$(rugix-ctrl system info)
ACTIVE=$(echo "$SYSTEM_INFO" | jq -r '.boot.activeGroup')
DEFAULT=$(echo "$SYSTEM_INFO" | jq -r '.boot.defaultGroup')

if [ "$ACTIVE" == "$DEFAULT" ]; then
    echo "[INFO] system committed (active=$ACTIVE), nothing to do" >&2
    exit 0
fi

echo "[WARN] system uncommitted after timeout (active=$ACTIVE, default=$DEFAULT), rebooting" >&2

nexigon-agent events emit --category "ota" \
    --severity "warning" \
    --attribute "activeGroup=$(jq -n --arg v "$ACTIVE" '$v')" \
    --attribute "defaultGroup=$(jq -n --arg v "$DEFAULT" '$v')" \
    '"watchdog triggering rollback reboot"' || true

reboot
