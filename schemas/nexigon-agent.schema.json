{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexigon_agent.config.Config",
  "type": "object",
  "description": "Agent configuration.",
  "properties": {
    "hub-url": {
      "type": "string"
    },
    "token": {
      "$ref": "#/$defs/nexigon_agent.config.DeploymentToken"
    },
    "fingerprint-script": {
      "$ref": "#/$defs/nexigon_agent.config.PathBuf"
    },
    "ssl-cert": {
      "$ref": "#/$defs/nexigon_agent.config.PathBuf"
    },
    "ssl-key": {
      "$ref": "#/$defs/nexigon_agent.config.PathBuf"
    },
    "dangerous-disable-tls": {
      "type": "boolean"
    },
    "telemetry": {
      "$ref": "#/$defs/nexigon_agent.config.TelemetryConfig"
    },
    "exports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nexigon_agent.config.ExportConfig"
      }
    },
    "terminal": {
      "$ref": "#/$defs/nexigon_agent.config.TerminalConfig"
    },
    "commands": {
      "$ref": "#/$defs/nexigon_agent.config.CommandsConfig"
    },
    "local-api": {
      "$ref": "#/$defs/nexigon_agent.config.LocalApiConfig"
    }
  },
  "required": [
    "hub-url",
    "token",
    "fingerprint-script"
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "nexigon_agent.config.CommandsConfig": {
      "$id": "nexigon_agent.config.CommandsConfig",
      "type": "object",
      "description": "On-demand command configuration.",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "directory": {
          "$ref": "#/$defs/nexigon_agent.config.PathBuf"
        }
      },
      "required": [],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.DeploymentToken": {
      "$id": "nexigon_agent.config.DeploymentToken",
      "type": [
        "string"
      ],
      "description": "Deployment token."
    },
    "nexigon_agent.config.ExportConfig": {
      "$id": "nexigon_agent.config.ExportConfig",
      "description": "Service export configuration.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "protocol": {
              "const": "http"
            },
            "name": {
              "type": "string"
            },
            "port": {},
            "path": {
              "type": "string"
            }
          },
          "required": [
            "protocol",
            "name",
            "port"
          ]
        }
      ]
    },
    "nexigon_agent.config.LocalApiConfig": {
      "$id": "nexigon_agent.config.LocalApiConfig",
      "type": "object",
      "description": "Local API configuration.\n\nControls the Unix socket exposed by the agent for in-host clients\n(CLI, SDKs) to invoke hub actions over the agent's existing\nconnection without establishing a fresh one.",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "socket-path": {
          "$ref": "#/$defs/nexigon_agent.config.PathBuf"
        }
      },
      "required": [],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.PathBuf": {
      "$id": "nexigon_agent.config.PathBuf",
      "type": [
        "string"
      ],
      "description": "Filesystem path."
    },
    "nexigon_agent.config.TelemetryConfig": {
      "$id": "nexigon_agent.config.TelemetryConfig",
      "type": "object",
      "description": "Telemetry configuration.\n\nControls automatic data collection the agent performs in the background.\nEach toggle is opt-out: defaults preserve historical behavior. Disabling\nthese is primarily useful for tests and tightly controlled deployments\nwhere the operator pushes the equivalent data manually via the CLI.",
      "properties": {
        "system-info": {
          "type": "boolean"
        }
      },
      "required": [],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.TerminalConfig": {
      "$id": "nexigon_agent.config.TerminalConfig",
      "type": "object",
      "description": "Remote terminal configuration.",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "user": {
          "type": "string"
        },
        "shell": {
          "type": "string"
        },
        "allowed-users": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [],
      "unevaluatedProperties": false
    }
  }
}