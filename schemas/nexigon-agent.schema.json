{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexigon_agent.config.Config",
  "type": "object",
  "description": "Agent configuration.",
  "properties": {
    "hub-url": {
      "type": "string"
    },
    "token": {
      "$ref": "#/$defs/nexigon_agent.config.DeploymentToken"
    },
    "fingerprint-script": {
      "$ref": "#/$defs/nexigon_agent.config.PathBuf"
    },
    "ssl-cert": {
      "$ref": "#/$defs/nexigon_agent.config.PathBuf"
    },
    "ssl-key": {
      "$ref": "#/$defs/nexigon_agent.config.PathBuf"
    },
    "dangerous-disable-tls": {
      "type": "boolean"
    },
    "disable-system-info": {
      "type": "boolean"
    },
    "exports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nexigon_agent.config.ExportConfig"
      }
    },
    "terminal": {
      "$ref": "#/$defs/nexigon_agent.config.TerminalConfig"
    },
    "commands": {
      "$ref": "#/$defs/nexigon_agent.config.CommandsConfig"
    }
  },
  "required": [
    "hub-url",
    "token",
    "fingerprint-script"
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "nexigon_agent.commands.CommandOutputLine": {
      "$id": "nexigon_agent.commands.CommandOutputLine",
      "type": "object",
      "description": "Command output line payload.",
      "properties": {
        "data": {
          "$ref": "#/$defs/nexigon_agent.commands.JsonValue"
        }
      },
      "required": [
        "data"
      ],
      "unevaluatedProperties": false
    },
    "nexigon_agent.commands.CommandStdoutLine": {
      "$id": "nexigon_agent.commands.CommandStdoutLine",
      "description": "Line written by a command to stdout.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "Output"
            },
            "data": {
              "$ref": "#/$defs/nexigon_agent.commands.JsonValue"
            }
          },
          "required": [
            "type",
            "data"
          ]
        }
      ]
    },
    "nexigon_agent.commands.JsonValue": {
      "$id": "nexigon_agent.commands.JsonValue",
      "description": "JSON value."
    },
    "nexigon_agent.config.BuiltinCommandGroupConfig": {
      "$id": "nexigon_agent.config.BuiltinCommandGroupConfig",
      "type": "object",
      "description": "Configuration for a group of built-in commands.",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.BuiltinCommandsConfig": {
      "$id": "nexigon_agent.config.BuiltinCommandsConfig",
      "type": "object",
      "description": "Built-in command configuration.",
      "properties": {
        "system": {
          "$ref": "#/$defs/nexigon_agent.config.BuiltinCommandGroupConfig"
        },
        "systemd": {
          "$ref": "#/$defs/nexigon_agent.config.BuiltinCommandGroupConfig"
        },
        "rugix-apps": {
          "$ref": "#/$defs/nexigon_agent.config.BuiltinCommandGroupConfig"
        }
      },
      "required": [],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.CommandDefinition": {
      "$id": "nexigon_agent.config.CommandDefinition",
      "type": "object",
      "description": "Command definition file.",
      "properties": {
        "command": {
          "$ref": "#/$defs/nexigon_agent.config.CommandMeta"
        },
        "input": {
          "$ref": "#/$defs/nexigon_agent.config.CommandSchemaBlock"
        },
        "output": {
          "$ref": "#/$defs/nexigon_agent.config.CommandSchemaBlock"
        },
        "exec": {
          "$ref": "#/$defs/nexigon_agent.config.CommandExec"
        }
      },
      "required": [
        "command",
        "exec"
      ],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.CommandExec": {
      "$id": "nexigon_agent.config.CommandExec",
      "type": "object",
      "description": "Command execution configuration.",
      "properties": {
        "handler": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeout": {
          "type": "integer",
          "format": "uint64"
        }
      },
      "required": [
        "handler"
      ],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.CommandMeta": {
      "$id": "nexigon_agent.config.CommandMeta",
      "type": "object",
      "description": "Command metadata.",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.CommandSchemaBlock": {
      "$id": "nexigon_agent.config.CommandSchemaBlock",
      "type": "object",
      "description": "JSON Schema block.",
      "properties": {
        "schema": {
          "type": "string"
        }
      },
      "required": [
        "schema"
      ],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.CommandsConfig": {
      "$id": "nexigon_agent.config.CommandsConfig",
      "type": "object",
      "description": "On-demand command configuration.",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "directory": {
          "$ref": "#/$defs/nexigon_agent.config.PathBuf"
        },
        "builtins": {
          "$ref": "#/$defs/nexigon_agent.config.BuiltinCommandsConfig"
        }
      },
      "required": [],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.DeploymentToken": {
      "$id": "nexigon_agent.config.DeploymentToken",
      "type": [
        "string"
      ],
      "description": "Deployment token."
    },
    "nexigon_agent.config.ExportConfig": {
      "$id": "nexigon_agent.config.ExportConfig",
      "description": "Service export configuration.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "protocol": {
              "const": "http"
            },
            "name": {
              "type": "string"
            },
            "port": {},
            "path": {
              "type": "string"
            }
          },
          "required": [
            "protocol",
            "name",
            "port"
          ]
        }
      ]
    },
    "nexigon_agent.config.HttpExportConfig": {
      "$id": "nexigon_agent.config.HttpExportConfig",
      "type": "object",
      "description": "HTTP export configuration.",
      "properties": {
        "name": {
          "type": "string"
        },
        "port": {},
        "path": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "port"
      ],
      "unevaluatedProperties": false
    },
    "nexigon_agent.config.PathBuf": {
      "$id": "nexigon_agent.config.PathBuf",
      "type": [
        "string"
      ],
      "description": "Filesystem path."
    },
    "nexigon_agent.config.TerminalConfig": {
      "$id": "nexigon_agent.config.TerminalConfig",
      "type": "object",
      "description": "Remote terminal configuration.",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "user": {
          "type": "string"
        },
        "shell": {
          "type": "string"
        },
        "allowed-users": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [],
      "unevaluatedProperties": false
    }
  }
}