/// Deployment token.
#[rust(type = "nexigon_ids::ids::DeploymentToken")]
#[json(type = "string")]
opaque DeploymentToken

/// Filesystem path.
#[rust(type = "std::path::PathBuf")]
#[json(type = "string")]
opaque PathBuf

/// Agent configuration.
#[json(rename_all = "kebab-case")]
record Config {
    /// URL of the Nexigon Hub server.
    hub_url: string,
    /// Deployment token.
    token: DeploymentToken,
    /// Fingerprint script.
    fingerprint_script: PathBuf,
    /// Path to the device certificate.
    ssl_cert?: PathBuf,
    /// Path to the device private key.
    ssl_key?: PathBuf,
    /// Disable TLS.
    dangerous_disable_tls?: bool,
    /// Telemetry configuration.
    telemetry?: TelemetryConfig,
    /// Exported services.
    exports?: [ExportConfig],
    /// Remote terminal configuration.
    terminal?: TerminalConfig,
    /// On-demand command configuration.
    commands?: CommandsConfig,
    /// Local API configuration.
    local_api?: LocalApiConfig,
}

/// Local API configuration.
///
/// Controls the Unix socket exposed by the agent for in-host clients
/// (CLI, SDKs) to invoke hub actions over the agent's existing
/// connection without establishing a fresh one.
#[json(rename_all = "kebab-case")]
record LocalApiConfig {
    /// Whether the local API is enabled (defaults to true).
    enabled?: bool,
    /// Path to the Unix socket
    /// (defaults to `/run/nexigon/agent/control/socket.sock`).
    socket_path?: PathBuf,
}

/// Telemetry configuration.
///
/// Controls automatic data collection the agent performs in the background.
/// Each toggle is opt-out: defaults preserve historical behavior. Disabling
/// these is primarily useful for tests and tightly controlled deployments
/// where the operator pushes the equivalent data manually via the CLI.
#[json(rename_all = "kebab-case")]
record TelemetryConfig {
    /// Whether to periodically publish `dev.nexigon.system.info` (defaults to true).
    system_info?: bool,
}

/// Service export configuration.
#[json(tag = "protocol", rename_all = "lowercase")]
variant ExportConfig {
    /// HTTP export configuration.
    Http: HttpExportConfig,
}

/// HTTP export configuration.
#[json(rename_all = "kebab-case")]
record HttpExportConfig {
    /// Name of the export.
    name: string,
    /// Port the service listens on.
    port: u16,
    /// URL path prefix for the service.
    path?: string,
}

/// Remote terminal configuration.
#[json(rename_all = "kebab-case")]
record TerminalConfig {
    /// Whether terminal access is enabled (defaults to false).
    enabled?: bool,
    /// Default Unix user for terminal sessions (defaults to `root`).
    user?: string,
    /// Default shell to use (fallback: user's login shell, then /bin/sh).
    shell?: string,
    /// Allowed users for terminal sessions. If not set, only the default user is permitted.
    allowed_users?: [string],
}

/// On-demand command configuration.
#[json(rename_all = "kebab-case")]
record CommandsConfig {
    /// Whether on-demand commands are enabled (defaults to false).
    enabled?: bool,
    /// Directory containing command definition files (defaults to /etc/nexigon/agent/commands).
    directory?: PathBuf,
}

/// Command definition file.
record CommandDefinition {
    /// Command metadata.
    command: CommandMeta,
    /// JSON Schema for the command input.
    input?: CommandSchemaBlock,
    /// JSON Schema for the command output.
    output?: CommandSchemaBlock,
    /// Execution configuration.
    exec: CommandExec,
}

/// Command metadata.
record CommandMeta {
    /// Command name.
    name: string,
    /// Description of what the command does.
    description?: string,
    /// Category for grouping in the UI.
    category?: string,
}

/// JSON Schema block.
record CommandSchemaBlock {
    /// JSON Schema as a string.
    schema: string,
}

/// Command execution configuration.
record CommandExec {
    /// Executable and arguments to run.
    handler: [string],
    /// Timeout in seconds (defaults to 30).
    timeout?: u64,
}
