
/// Deployment token.
#[rust(type = "nexigon_ids::ids::DeploymentToken")]
#[json(type = "string")]
opaque DeploymentToken

/// Filesystem path.
#[rust(type = "std::path::PathBuf")]
#[json(type = "string")]
opaque PathBuf

/// Agent configuration.
#[json(rename_all = "kebab-case")]
record Config {
    /// URL of the Nexigon Hub server.
    hub_url: string,
    /// Deployment token.
    token: DeploymentToken,
    /// Fingerprint script.
    fingerprint_script: PathBuf,
    /// Path to the device certificate.
    ssl_cert?: PathBuf,
    /// Path to the device private key.
    ssl_key?: PathBuf,
    /// Disable TLS.
    dangerous_disable_tls?: bool,
    /// Disable system info telemetry.
    disable_system_info?: bool,
    /// Exported services.
    exports?: [ExportConfig],
    /// Remote terminal configuration.
    terminal?: TerminalConfig,
    /// On-demand command configuration.
    commands?: CommandsConfig,
    /// Integration configuration.
    integrations?: IntegrationsConfig,
}

/// Service export configuration.
#[json(tag = "protocol", rename_all = "lowercase")]
variant ExportConfig {
    /// HTTP export configuration.
    Http: HttpExportConfig,
}

/// HTTP export configuration.
#[json(rename_all = "kebab-case")]
record HttpExportConfig {
    /// Name of the export.
    name: string,
    /// Port the service listens on.
    port: u16,
    /// URL path prefix for the service.
    path?: string,
}

/// Remote terminal configuration.
#[json(rename_all = "kebab-case")]
record TerminalConfig {
    /// Whether terminal access is enabled (defaults to false).
    enabled?: bool,
    /// Default Unix user for terminal sessions.
    user?: string,
    /// Default shell to use (fallback: user's login shell, then /bin/sh).
    shell?: string,
    /// Allowed users for terminal sessions. If not set, any user is allowed.
    allowed_users?: [string],
}

/// On-demand command configuration.
#[json(rename_all = "kebab-case")]
record CommandsConfig {
    /// Whether on-demand commands are enabled (defaults to false).
    enabled?: bool,
    /// Directory containing command definition files (defaults to /etc/nexigon/agent/commands).
    directory?: PathBuf,
    /// Built-in command configuration.
    builtins?: BuiltinCommandsConfig,
}

/// Built-in command configuration.
#[json(rename_all = "kebab-case")]
record BuiltinCommandsConfig {
    /// System power commands (reboot, shutdown).
    system?: BuiltinCommandGroupConfig,
    /// Systemd service management commands.
    systemd?: BuiltinCommandGroupConfig,
}

/// Configuration for a group of built-in commands.
#[json(rename_all = "kebab-case")]
record BuiltinCommandGroupConfig {
    /// Whether this group of built-in commands is enabled (defaults to false).
    enabled?: bool,
}

/// Integration configuration.
#[json(rename_all = "kebab-case")]
record IntegrationsConfig {
    /// Rugix Apps integration.
    rugix_apps?: RugixAppsConfig,
}

/// Rugix Apps integration configuration.
#[json(rename_all = "kebab-case")]
record RugixAppsConfig {
    /// Whether the Rugix Apps integration is enabled (defaults to false).
    enabled?: bool,
}

/// Command definition file.
record CommandDefinition {
    /// Command metadata.
    command: CommandMeta,
    /// JSON Schema for the command input.
    input?: CommandSchemaBlock,
    /// JSON Schema for the command output.
    output?: CommandSchemaBlock,
    /// Execution configuration.
    exec: CommandExec,
}

/// Command metadata.
record CommandMeta {
    /// Command name.
    name: string,
    /// Description of what the command does.
    description?: string,
    /// Category for grouping in the UI.
    category?: string,
}

/// JSON Schema block.
record CommandSchemaBlock {
    /// JSON Schema as a string.
    schema: string,
}

/// Command execution configuration.
record CommandExec {
    /// Executable and arguments to run.
    handler: [string],
    /// Timeout in seconds (defaults to 30).
    timeout?: u64,
}

